# Prompt Relay — environment configuration.
# Copy this file to `.env` and fill in your values. NEVER commit the real .env.

# --- Supabase (required) -----------------------------------------------------
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# Service-role key — SERVER-SIDE ONLY. Bypasses RLS; used by FastAPI to write
# game rows, the leaderboard, and to upload images. Keep this secret.
SUPABASE_SERVICE_KEY=
# Anon (public) key — safe to expose to the browser. Used only for read-only
# realtime leaderboard subscriptions.
SUPABASE_ANON_KEY=
# Public Storage bucket name for reference + generated images (default: images).
SUPABASE_STORAGE_BUCKET=images

# --- AI providers ------------------------------------------------------------
# At least one is recommended for real images. With none set and ENABLE_MOCK=true
# the game still runs end-to-end on the keyless mock provider.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Ordered list of real providers to try before the mock (comma-separated).
PROVIDER_ORDER=gemini,openai

# Append the keyless mock as a final fallback so the app always has a working
# provider. Set to false to instead surface a hard error when all real providers
# fail (matches the spec's "if all providers fail" behavior).
ENABLE_MOCK=true

# --- Optional model id overrides ---------------------------------------------
# Provider model names change over time; override here if a call 404s.
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_VISION_MODEL=gemini-2.0-flash
# OPENAI_IMAGE_MODEL defaults to gpt-image-1-mini (cheapest + fastest). Use
# gpt-image-1 for higher fidelity at higher cost.
# OPENAI_IMAGE_MODEL=gpt-image-1-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

# Image quality tier: low | medium | high | auto. Lower = fewer image tokens =
# cheaper AND faster. Default "low" is cheapest/fastest; bump to "medium" for a
# nicer picture at some cost/speed.
OPENAI_IMAGE_QUALITY=low

# --- Timing (seconds) --------------------------------------------------------
# Seconds allowed per prompt before it auto-submits.
PROMPT_SECONDS=30
